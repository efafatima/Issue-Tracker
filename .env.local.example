NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

BOT_API_KEY=change-this-bot-key
AUTH_AUTO_CONFIRM_STUDENTS=false

EMAIL_APP_NAME=IssueTracker
EMAIL_DRY_RUN=true
GMAIL_USER=your-gmail-address@example.com
GMAIL_APP_PASSWORD=your-gmail-app-password
EMAIL_FROM="IssueTracker <your-gmail-address@example.com>"
APP_URL=http://localhost:3000

# Botpress student chatbot
NEXT_PUBLIC_BOTPRESS_SCRIPT_URL=https://cdn.botpress.cloud/webchat/v3.6/inject.js
NEXT_PUBLIC_BOTPRESS_BOT_ID=your-botpress-bot-id
NEXT_PUBLIC_BOTPRESS_CLIENT_ID=your-botpress-client-id
NEXT_PUBLIC_BOTPRESS_CONFIG_URL=your-botpress-config-script-url
